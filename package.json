{
  "name": "meshmonitor",
  "version": "4.0.0-beta14",
  "description": "Web application for monitoring Meshtastic nodes over IP",
  "license": "BSD-3-Clause",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx --watch src/server/server.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc && vite build",
    "build:server": "tsc --project tsconfig.server.json && mkdir -p dist/server/routes/v1 && cp src/server/routes/v1/openapi.yaml dist/server/routes/v1/",
    "start": "node dist/server/server.js",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:quick-start": "tests/test-quick-start.sh",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:db:down": "docker compose -f docker-compose.test.yml down -v",
    "test:multidb": "npm run test:db:up && vitest run; code=$?; npm run test:db:down; exit $code",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "migrate-db": "node dist/cli/migrate-db.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@maplibre/maplibre-gl-leaflet": "^0.1.3",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-virtual": "^3.13.24",
    "@tmcw/togeojson": "^7.1.2",
    "@types/pbf": "^3.0.5",
    "@xmldom/xmldom": "^0.9.10",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.9.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "cron-validator": "^1.4.0",
    "croner": "^10.0.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-mysql-session": "^3.0.3",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
