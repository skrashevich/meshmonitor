    "maplibre-gl": "^5.23.0",
    "morgan": "^1.10.1",
    "mysql2": "^3.22.3",
    "node-notifier": "^10.0.1",
    "openid-client": "^6.8.3",
    "otplib": "^13.4.0",
    "pbf": "^4.0.1",
    "pg": "^8.20.0",
    "protobufjs": "^8.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
